<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Logo Editor | Admin</title>
  <link rel="stylesheet" href="/css/theme.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <%- include('_nav') %>
  <main class="admin-main">
    <div class="admin-header">
      <h1>Logo Management</h1>
      <button onclick="saveLogo()" class="btn-admin btn-admin--primary" id="saveBtn">Save Logo</button>
    </div>

    <div class="admin-section">
      <h2>Logo Type</h2>
      <div class="radio-group">
        <label class="radio-label">
          <input type="radio" name="logo_type" value="text" <%= settings.logo_type === 'text' ? 'checked' : '' %>> Text Logo
        </label>
        <label class="radio-label">
          <input type="radio" name="logo_type" value="image" <%= settings.logo_type === 'image' ? 'checked' : '' %>> Image Logo
        </label>
      </div>
    </div>

    <div class="admin-section" id="text-logo-section">
      <h2>Text Logo</h2>
      <div class="admin-form-grid">
        <div class="form-group">
          <label>Monogram (e.g. "DT")</label>
          <input type="text" id="logo_text" value="<%= settings.logo_text %>" class="admin-input" maxlength="4">
        </div>
        <div class="form-group">
          <label>Brand Name</label>
          <input type="text" id="logo_subtext" value="<%= settings.logo_subtext %>" class="admin-input">
        </div>
      </div>
      <div class="logo-preview">
        <div class="logo-preview__mark" id="previewMark"><%= settings.logo_text %></div>
        <span id="previewText"><%= settings.logo_subtext %></span>
      </div>
    </div>

    <div class="admin-section" id="image-logo-section">
      <h2>Image Logo</h2>
      <% if (settings.logo_image_path) { %>
      <div class="logo-preview">
        <img src="<%= settings.logo_image_path %>" alt="Current logo" style="max-height:60px;">
      </div>
      <% } %>
      <form id="logoUploadForm">
        <input type="file" accept="image/*" id="logoFile" class="image-file-input">
        <label for="logoFile" class="btn-admin">Choose Logo Image</label>
        <button type="submit" class="btn-admin btn-admin--primary btn-admin--sm">Upload Logo</button>
      </form>
      <p class="form-hint">Logo will be resized to max 400x200px and converted to WebP.</p>
    </div>

    <div id="toast" class="toast"></div>
  </main>

  <script>
    document.getElementById('logo_text').addEventListener('input', (e) => {
      document.getElementById('previewMark').textContent = e.target.value;
    });
    document.getElementById('logo_subtext').addEventListener('input', (e) => {
      document.getElementById('previewText').textContent = e.target.value;
    });

    function showToast(msg, type) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.className = 'toast toast--' + type + ' toast--visible';
      setTimeout(() => t.classList.remove('toast--visible'), 3000);
    }

    async function saveLogo() {
      const btn = document.getElementById('saveBtn');
      btn.textContent = 'Saving...';
      btn.disabled = true;
      try {
        const logoType = document.querySelector('input[name="logo_type"]:checked').value;
        await fetch('/api/logo', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            logo_type: logoType,
            logo_text: document.getElementById('logo_text').value,
            logo_subtext: document.getElementById('logo_subtext').value
          })
        });
        showToast('Logo saved!', 'success');
      } catch (err) {
        showToast('Error: ' + err.message, 'error');
      }
      btn.textContent = 'Save Logo';
      btn.disabled = false;
    }

    document.getElementById('logoUploadForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const fileInput = document.getElementById('logoFile');
      if (!fileInput.files.length) return showToast('Choose a file first', 'error');
      const formData = new FormData();
      formData.append('image', fileInput.files[0]);
      try {
        const res = await fetch('/api/logo/upload', { method: 'POST', body: formData });
        const data = await res.json();
        if (data.success) {
          showToast('Logo uploaded!', 'success');
          location.reload();
        }
      } catch (err) {
        showToast('Upload failed', 'error');
      }
    });
  </script>
</body>
</html>
