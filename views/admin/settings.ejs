<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Site Settings | Admin</title>
  <link rel="stylesheet" href="/css/theme.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
  <%- include('_nav') %>
  <main class="admin-main">
    <div class="admin-header">
      <h1>Site Settings</h1>
      <button onclick="saveSettings()" class="btn-admin btn-admin--primary" id="saveBtn">Save Settings</button>
    </div>

    <div class="admin-section">
      <h2>Contact Information</h2>
      <div class="admin-form-grid">
        <div class="form-group">
          <label>Primary Phone</label>
          <input type="text" data-key="phone_primary" value="<%= settings.phone_primary %>" class="admin-input setting-field">
        </div>
        <div class="form-group">
          <label>Secondary Phone</label>
          <input type="text" data-key="phone_secondary" value="<%= settings.phone_secondary %>" class="admin-input setting-field">
        </div>
        <div class="form-group">
          <label>Email</label>
          <input type="email" data-key="email" value="<%= settings.email %>" class="admin-input setting-field">
        </div>
        <div class="form-group">
          <label>WhatsApp URL</label>
          <input type="text" data-key="whatsapp_url" value="<%= settings.whatsapp_url %>" class="admin-input setting-field">
        </div>
        <div class="form-group">
          <label>Instagram URL</label>
          <input type="text" data-key="instagram_url" value="<%= settings.instagram_url %>" class="admin-input setting-field">
        </div>
      </div>
    </div>

    <div class="admin-section">
      <h2>Address</h2>
      <div class="admin-form-grid">
        <div class="form-group">
          <label>Street Address</label>
          <input type="text" data-key="address_street" value="<%= settings.address_street %>" class="admin-input setting-field">
        </div>
        <div class="form-group">
          <label>Locality</label>
          <input type="text" data-key="address_locality" value="<%= settings.address_locality %>" class="admin-input setting-field">
        </div>
        <div class="form-group">
          <label>Postcode</label>
          <input type="text" data-key="address_postcode" value="<%= settings.address_postcode %>" class="admin-input setting-field">
        </div>
        <div class="form-group">
          <label>Opening Hours Display</label>
          <input type="text" data-key="opening_hours_display" value="<%= settings.opening_hours_display %>" class="admin-input setting-field">
        </div>
      </div>
    </div>

    <div class="admin-section">
      <h2>Site Info</h2>
      <div class="admin-form-grid">
        <div class="form-group">
          <label>Site Name</label>
          <input type="text" data-key="site_name" value="<%= settings.site_name %>" class="admin-input setting-field">
        </div>
        <div class="form-group">
          <label>Footer Description</label>
          <textarea data-key="footer_brand_desc" class="admin-input setting-field" rows="2"><%= settings.footer_brand_desc %></textarea>
        </div>
        <div class="form-group">
          <label>Delivery Rate</label>
          <input type="text" data-key="delivery_rate" value="<%= settings.delivery_rate %>" class="admin-input setting-field">
        </div>
        <div class="form-group">
          <label>Google Maps Embed URL</label>
          <input type="text" data-key="maps_embed_url" value="<%= settings.maps_embed_url %>" class="admin-input setting-field">
        </div>
      </div>
    </div>

    <div id="toast" class="toast"></div>
  </main>

  <script>
    function showToast(msg, type) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.className = 'toast toast--' + type + ' toast--visible';
      setTimeout(() => t.classList.remove('toast--visible'), 3000);
    }

    async function saveSettings() {
      const btn = document.getElementById('saveBtn');
      btn.textContent = 'Saving...';
      btn.disabled = true;

      const data = {};
      document.querySelectorAll('.setting-field').forEach(el => {
        data[el.dataset.key] = el.value;
      });

      try {
        const res = await fetch('/api/settings', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        const result = await res.json();
        if (result.success) showToast('Settings saved!', 'success');
        else showToast('Error: ' + result.error, 'error');
      } catch (err) {
        showToast('Error: ' + err.message, 'error');
      }

      btn.textContent = 'Save Settings';
      btn.disabled = false;
    }
  </script>
</body>
</html>
